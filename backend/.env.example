DATABASE_URL=
PORT=3210

# Solana Attestation Service (SAS)
# Run `npm run sas:setup` to generate these values
SOLANA_RPC_URL=
SAS_ISSUER_KEYPAIR=
SAS_CREDENTIAL_PDA=
SAS_SCHEMA_PDA=

# AMINA Vault Program (Anchor)
# Set this to the deployed program ID after running `anchor deploy`
# The AMINA_BANK_KEYPAIR is the wallet that deploys all vault contracts.
# Falls back to SAS_ISSUER_KEYPAIR if not set.
AMINA_PROGRAM_ID=
AMINA_BANK_KEYPAIR=

# Contract verification: when 'true', deployed program instances are verified
# against the canonical template binary during vault creation.
VERIFY_CONTRACTS=true

# USX Instructions API (Solstice)
USX_API_URL=
USX_API_KEY=

ENCIFHER_SDK_KEY=your_key_from_encifher_team
ENCIFHER_ENABLED=false
ENCIFHER_MODE=Devnet

MOCK_TRANSLATION_LAYER_PROGRAM_ID=
MOCK_FINSTAR_PROGRAM_ID=
MOCK_NOTABENE_PROGRAM_ID=
MOCK_MESH_PROGRAM_ID=
MOCK_JURISDICTION_PROGRAM_ID=

# Translation Layer toggle
USE_TRANSLATION_LAYER=true