generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Credential {
  id                 String   @id @default(uuid())
  credentialId       String   @unique
  clientReference    String
  jurisdiction       String
  riskTier           String
  productEligibility String
  walletAddress      String
  status             String   @default("active")
  revoked            Boolean  @default(false)
  attestationPda     String?
  attestationTxSig   String?
  issuedAt           DateTime @default(now())
  expiryAt           DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  vaults             Vault[]
}

model Vault {
  id                    String   @id @default(uuid())
  vaultId               String   @unique
  credentialId          String
  credential            Credential @relation(fields: [credentialId], references: [credentialId])
  clientReference       String
  ownerWallet           String
  baseAsset             String   @default("USDC")
  status                String   @default("active")
  paused                Boolean  @default(false)
  idleBalance           Float    @default(0)
  totalDeposited        Float    @default(0)
  totalNAV              Float    @default(0)
  vaultAttestationPda   String?
  vaultAttestationTxSig String?
  onChainAddress        String?
  programId             String?
  programVerified       Boolean  @default(false)
  programVerifiedAt     DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  mandate               Mandate?
  deposits              Deposit[]
  allocations           Allocation[]
  tlInstructions        TranslationLayerInstruction[]
  glEntries             GLEntry[]
  mandateRules          MandateRule[]
  consentRequests       ConsentRequest[]
  complianceEvents      ComplianceEvent[]
}

model Mandate {
  id                    String   @id @default(uuid())
  vaultId               String   @unique
  vault                 Vault    @relation(fields: [vaultId], references: [vaultId])
  allowedStrategies     String[]
  blockedStrategies     String[]
  maxAllocationBps      Json
  liquidityBufferBps    Int      @default(1000)
  consentThreshold      Float    @default(250000)
  leverageAllowed       Boolean  @default(false)
  approvedDestinations  String[]
  status                String   @default("active")
  version               Int      @default(1)
  lastUpdatedBy         String?
  onChainSynced         Boolean  @default(false)
  onChainSyncTx         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model MandateRule {
  id          String   @id @default(uuid())
  vaultId     String
  vault       Vault    @relation(fields: [vaultId], references: [vaultId])
  ruleType    String
  params      Json
  status      String   @default("active")
  version     Int      @default(1)
  createdBy   String
  onChainSync Boolean  @default(false)
  onChainTx   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Strategy {
  id            String   @id @default(uuid())
  strategyId    String   @unique
  name          String
  description   String
  riskLevel     String
  active        Boolean  @default(true)
  disabled      Boolean  @default(false)
  currentYield  Float    @default(0)
  providerId    String?
  provider      ProviderProfile? @relation("ProviderStrategies", fields: [providerId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  allocations   Allocation[]
}

model Allocation {
  id            String   @id @default(uuid())
  vaultId       String
  vault         Vault    @relation(fields: [vaultId], references: [vaultId])
  strategyId    String
  strategy      Strategy @relation(fields: [strategyId], references: [strategyId])
  amount        Float
  yieldAccrued  Float    @default(0)
  status        String   @default("active")
  txSignature   String?
  onChainAddress String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Deposit {
  id              String   @id @default(uuid())
  vaultId         String
  vault           Vault    @relation(fields: [vaultId], references: [vaultId])
  amount          Float
  sourceWallet    String
  sourceReference String
  sourceType      String   @default("Approved Custody-Linked Wallet")
  screeningStatus String   @default("Clear")
  jurisdictionTag String   @default("CH")
  createdAt       DateTime @default(now())
}

model ConsentRequest {
  id          String   @id @default(uuid())
  requestId   String   @unique
  vaultId     String
  vault       Vault    @relation(fields: [vaultId], references: [vaultId])
  actionType  String
  amount      Float
  details     Json?
  initiator   String
  status      String   @default("pending")
  consentedBy String?
  consentedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ComplianceEvent {
  id                  String   @id @default(uuid())
  eventId             String   @unique
  vaultId             String?
  vault               Vault?   @relation(fields: [vaultId], references: [vaultId])
  actionType          String
  actor               String
  role                String
  asset               String?
  amount              Float?
  strategy            String?
  result              String
  reason              String?
  txSignature         String?
  onChainAddress      String?
  translationLayerRef String?
  compliancePda       String?
  travelRulePda       String?
  routingPda          String?
  glEntryPda          String?
  timestamp           DateTime @default(now())
}

model AdminUser {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model SystemConfig {
  id        String   @id @default("singleton")
  bankBalance Float  @default(50000)
  updatedAt DateTime @updatedAt
}

// ─── Provider Approval Profile ───────────────────────────
model ProviderProfile {
  id                    String   @id @default(uuid())
  providerName          String
  strategy              String
  status                String   @default("APPROVED") // APPROVED | RESTRICTED | BLOCKED
  bankReviewStatus      String   @default("Completed")
  providerType          String   @default("Approved External Yield Provider")
  kytStatus             String   @default("Clear")
  ofacSanctionsStatus   String   @default("Clear")
  travelRuleTreatment   String   @default("External transfer edge review applied where applicable")
  protocolDueDiligence  String   @default("Completed")
  mandateFit            String[]
  exposureLimit         Int      @default(60) // percentage of vault NAV
  lastReviewDate        DateTime
  nextReviewDate        DateTime
  reviewNotes           String?
  evidencePackUrl       String?
  // Compliance Profile Fields 
  jurisdictionTreatment String   @default("Bank-reviewed")
  clientEligibility     String   @default("Institutional only")
  vaultEligibility      String[]
  destinationWallet     String   @default("Approved")
  kytScreeningRequired  Boolean  @default(true)
  ofacScreeningRequired Boolean  @default(true)
  travelRuleRequired    Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  strategies            Strategy[] @relation("ProviderStrategies")
  monitoringSnapshots   ProviderMonitoringSnapshot[]
}

// ─── Provider Monitoring Snapshot ────────────────────────
model ProviderMonitoringSnapshot {
  id                 String   @id @default(uuid())
  providerId         String
  provider           ProviderProfile @relation(fields: [providerId], references: [id])
  bankApprovalStatus String   @default("Approved")
  strategyStatus     String   @default("Available")
  contractMonitoring String   @default("No new critical event")
  kytExposure        String   @default("Clear")
  ofacStatus         String   @default("Clear")
  liquidityStatus    String   @default("Within approved range")
  reviewStatus       String   @default("Current")
  lastReviewed       DateTime
  nextReview         DateTime
  alerts             Json?
  snapshotDate       DateTime @default(now())
}

// ─── Transfer Check Matrix ───────────────────────────────
model TransferCheck {
  id                   String   @id @default(uuid())
  transferId           String
  transferType         String   // DEPOSIT | ALLOCATION | REDEMPTION | UNWIND
  vaultId              String
  fromAddress          String
  fromController       String
  toAddress            String
  toController         String
  asset                String   @default("USDC")
  amount               Float
  kytStatus            String   @default("CLEAR") // CLEAR | FLAGGED | PENDING | NOT_REQUIRED
  kytReference         String?
  ofacStatus           String   @default("CLEAR") // CLEAR | FLAGGED | PENDING | NOT_REQUIRED
  ofacReference        String?
  travelRuleStatus     String   @default("NOT_REQUIRED") // CLEAR | REQUIRED | COMPLETE | PENDING | NOT_REQUIRED
  travelRuleReference  String?
  providerApproval     String?  // APPROVED | NOT_REQUIRED
  mandateCheck         String?  // PASSED | FAILED | NOT_REQUIRED
  overallStatus        String   @default("PASSED") // PASSED | BLOCKED | PENDING_REVIEW
  txSignature          String?  // Solana tx signature if on-chain; null = bank/off-chain transfer
  checkedAt            DateTime @default(now())
  checkedBy            String?
}

// ─── Wallet Controller Registry ──────────────────────────
model WalletController {
  id                 String   @id @default(uuid())
  address            String   @unique
  controllerName     String
  controllerType     String   // BANK_TREASURY | CLIENT_ACCOUNT | SEGREGATED_VAULT | PROVIDER_ADDRESS | REDEMPTION_WALLET | UNKNOWN
  permittedUse       String
  verificationStatus String   @default("VERIFIED") // VERIFIED | PENDING | UNVERIFIED
  chainalysisLink    String?
  explorerLink       String?
  vaultId            String?
  vaultName          String?
  providerId         String?
  bankNumber         String?
  accountNumber      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─── Translation Layer Instruction (L2 Pipeline) ────────
model TranslationLayerInstruction {
  id                String   @id @default(uuid())
  instructionId     String   @unique
  instructionType   String   // DEPOSIT, ALLOCATE, REDEEM, UNWIND, PAUSE, MANDATE_UPDATE
  vaultId           String
  vault             Vault    @relation(fields: [vaultId], references: [vaultId])
  amount            Float    @default(0)
  jurisdiction      String   @default("CH")
  strategyId        String?

  status            String   @default("received") // received, compliance_checked, complete, failed
  complianceResult  String?  // passed, failed
  complianceRef     String?
  travelRuleRef     String?
  travelRuleResult  String?
  routingRef        String?
  glEntryRef        String?
  glEntryType       String?  // Deposit, StrategyAllocation, StrategyUnwind, Withdrawal, etc.
  glDirection       String?  // credit, debit

  initiator         String?
  rejectionReason   String?

  receivedAt        DateTime @default(now())
  complianceCheckedAt DateTime?
  actionExecutedAt  DateTime?
  completedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model GLEntry {
  id              String   @id @default(uuid())
  entryId         String   @unique
  vaultId         String
  vault           Vault    @relation(fields: [vaultId], references: [vaultId])
  instructionId   String?

  entryType       String   // Deposit, StrategyAllocation, StrategyUnwind, Withdrawal, YieldAccrual, FeeDebit
  direction       String   // credit, debit
  amount          Float
  currency        String   @default("USDC")

  debitAccount    String
  creditAccount   String
  narrative       String?

  swiftReference  String?
  jurisdiction    String   @default("CH")

  status          String   @default("pending") // pending, approved, posted, rejected
  approvedBy      String?
  approvedAt      DateTime?
  postedAt        DateTime?
  rejectionReason String?

  sourceType      String?  // deposit, allocation, transfer_check, manual
  sourceId        String?  // FK to source record

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
